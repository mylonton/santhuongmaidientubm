@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0 rounded-3">
            <div class="card-body p-4">
                <h3 class="text-center fw-bold text-primary mb-4">ĐĂNG NHẬP</h3>
                
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tài khoản</label>
                        <input type="text" name="username" class="form-control rounded-pill" placeholder="Nhập admin..." required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold">Mật khẩu</label>
                        <input type="password" name="password" class="form-control rounded-pill" placeholder="Nhập 123..." required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">VÀO HỆ THỐNG</button>
                </form>
                
                <div class="text-center mt-3">
                    <small class="text-muted">Chưa có tài khoản? <a asp-action="Register" class="text-decoration-none">Đăng ký</a></small>
                </div>
            </div>
        </div>
    </div>
</div>
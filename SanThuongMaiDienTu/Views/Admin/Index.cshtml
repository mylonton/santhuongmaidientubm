
@model IEnumerable<SanThuongMaiDienTu.Models.Order>

<div class="container mt-4">

    <!-- TIÊU ĐỀ -->
    <h2 class="fw-bold text-danger mb-4 border-bottom pb-2">
        QUẢN LÝ ĐƠN HÀNG
    </h2>

    <!--  THỐNG KÊ -->
    <div class="row text-center mb-4">

        <div class="col-md-3">
            <div class="card bg-success text-white p-3 shadow-sm">
                <h6>Doanh thu</h6>
                <h4>@ViewBag.TotalRevenue.ToString("#,##0") ₫</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-primary text-white p-3 shadow-sm">
                <h6>Đơn hàng</h6>
                <h4>@ViewBag.TotalOrders</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-dark p-3 shadow-sm">
                <h6>Sản phẩm</h6>
                <h4>@ViewBag.TotalProducts</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-danger text-white p-3 shadow-sm">
                <h6>Tồn kho</h6>
                <h4>@ViewBag.TotalStock</h4>
            </div>
        </div>

    </div>

    <!-- 📈 BIỂU ĐỒ -->
    <div class="card p-3 mb-4 shadow-sm">
        <h5 class="mb-3">Biểu đồ doanh thu (7 ngày gần nhất)</h5>
        <canvas id="revenueChart"></canvas>
    </div>

    <!-- 📋 BẢNG ĐƠN HÀNG -->
    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Mã Đơn</th>
                <th>Ngày Đặt</th>
                <th>SĐT</th>
                <th>Địa Chỉ</th>
                <th>Tổng Tiền</th>
                <th>Trạng Thái</th>
                <th>Thao Tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (Order item in Model)
            {
                <tr>
                    <td>#@item.Id</td>
                    <td>@item.OrderDate.ToString(format: "dd/MM/yyyy")</td>
                    <td>@item.Phone</td>
                    <td>@item.Address</td>

                    <td class="text-danger fw-bold">
                        @item.TotalAmount.ToString(format: "#,##0") đ
                    </td>

                    <td>
                        @if (item.IsDelivered)
                        {
                            <span class="badge bg-success">Đã giao</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Chờ xử lý</span>
                        }
                    </td>

                    <td>
                        <form asp-action="UpdateStatus" asp-route-id="@item.Id" method="post">
                            <button type="submit"
                                    class="btn btn-sm @(item.IsDelivered ? "btn-secondary" : "btn-primary")">
                                @(item.IsDelivered ? "Hoàn tác" : "Giao hàng")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

<!-- CHART JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    var ctx = document.getElementById('revenueChart').getContext('2d');

    var chart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.ChartLabels)),
            datasets: [{
                label: 'Doanh thu',
                data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.ChartData)),
                borderWidth: 2,
                tension: 0.4
            }]
        }
    });
</script>

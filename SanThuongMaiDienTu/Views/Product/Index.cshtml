@model IEnumerable<SanThuongMaiDienTu.Models.Product>

@{
    ViewData[index: "Title"] = "Quản lý sản phẩm & Kho hàng";
    Layout = "_Layout"; // Hoặc _AdminLayout nếu bạn đã tạo
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-uppercase fw-bold text-primary">Hệ thống Quản lý Kho BM</h2>
        <a asp-action="Create" class="btn btn-success px-4 shadow-sm">
            <i class="bi bi-plus-circle me-2"></i>Thêm sản phẩm mới
        </a>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4">Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá bán (VND)</th>
                        <th>Tồn kho</th>
                        <th>Trạng thái kho</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Product item in Model) {
                        <tr>
                            <td class="ps-4">
                                <img src="@item.ImageUrl" alt="@item.Name" style="width: 50px; height: 50px; object-fit: contain;" class="rounded border" />
                            </td>
                            <td><span class="fw-bold text-dark">@item.Name</span></td>
                            <td><span class="badge bg-light text-dark border">@item.Category?.Name</span></td>
                            <td><span class="text-danger fw-bold">@item.Price.ToString("#,##0") ₫</span></td>
                            <td class="text-center">@item.StockQuantity</td>
                            <td>
                                @if (item.StockQuantity > 10) {
                                    <span class="badge bg-success">Đang sẵn hàng</span>
                                } else if (item.StockQuantity > 0) {
                                    <span class="badge bg-warning text-dark">Sắp hết hàng</span>
                                } else {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Xem</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
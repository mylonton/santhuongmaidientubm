@model List<SanThuongMaiDienTu.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="container py-5">
    <div class="row">
        @if (Model != null && Model.Count > 0)
        {
            <div class="col-lg-8">
                <h4 class="fw-bold mb-4">GIỎ HÀNG (@Model.Count món)</h4>
                <div class="card shadow-sm border-0 rounded-3 mb-4">
                    <div class="card-body p-0">
                        <table class="table table-borderless align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="small text-muted text-uppercase">
                                    <th class="ps-4">Sản phẩm</th>
                                    <th>Số lượng</th>
                                    <th class="text-end pe-4">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="border-bottom">
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <img src="@item.Image" style="width: 70px; height: 70px; object-fit: cover;" class="me-3 rounded" onerror="this.src='/images/no-image.png'">
                                                <div>
                                                    <h6 class="mb-0 fw-bold">@item.ProductName</h6>
                                                    <small class="text-muted">Đơn giá: @item.Price.ToString("#,##0") ₫</small>
                                                    <br />
                                                    @* Thêm nút xóa sản phẩm *@
                                                    <a asp-action="Remove" asp-route-id="@item.ProductId" class="text-danger small text-decoration-none">Xóa</a>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @* Nút giảm số lượng *@
                                                <a asp-action="UpdateQuantity" asp-route-id="@item.ProductId" asp-route-quantity="@(item.Quantity - 1)" class="btn btn-sm btn-light border">-</a>
                                                
                                                <span class="mx-3 fw-bold">@item.Quantity</span>
                                                
                                                @* Nút tăng số lượng *@
                                                <a asp-action="UpdateQuantity" asp-route-id="@item.ProductId" asp-route-quantity="@(item.Quantity + 1)" class="btn btn-sm btn-light border">+</a>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4 fw-bold text-danger">@item.Total.ToString("#,##0") ₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <a asp-controller="Home" asp-action="Index" class="btn btn-link text-decoration-none p-0 text-primary">
                    <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
                </a>
            </div>

            <div class="col-lg-4">
                <form asp-action="Checkout" method="post">
                    <div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
                        <h5 class="fw-bold mb-4">THÔNG TIN THANH TOÁN</h5>
                        
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase">Hình thức thanh toán</label>
                            <select name="paymentMethod" class="form-select mb-2">
                                <option value="COD" selected>Thanh toán khi nhận hàng (COD)</option>
                                <option value="Bank">Chuyển khoản qua Ngân hàng</option>
                                <option value="EWallet">Ví điện tử MoMo / VNPay</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Tạm tính:</span>
                            <span>@Model.Sum(x => x.Total).ToString("#,##0") ₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 border-bottom pb-2">
                            <span>Phí vận chuyển:</span>
                            <span class="text-success">Miễn phí</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold">TỔNG CỘNG:</span>
                            <h4 class="text-danger fw-bold">@Model.Sum(x => x.Total).ToString("#,##0") ₫</h4>
                        </div>

                        <button type="submit" class="btn btn-warning w-100 fw-bold py-3 rounded-pill shadow">
                            XÁC NHẬN ĐẶT HÀNG
                        </button>
                    </div>
                </form>
            </div>
        }
        else
        {
            @* Giữ nguyên phần giỏ hàng trống của ông *@
            <div class="col-12 text-center py-5">
                <i class="bi bi-cart-x text-muted display-1"></i>
                <h3 class="mt-4">Giỏ hàng của bạn đang trống</h3>
                <p class="text-muted">Hãy quay lại trang chủ để chọn sản phẩm ưng ý nhé!</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-5 py-2 rounded-pill mt-3">MUA SẮM NGAY</a>
            </div>
        }
    </div>
</div>
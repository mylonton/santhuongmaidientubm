@model IEnumerable<SanThuongMaiDienTu.Models.Product>

@if (TempData["SearchError"] != null)
{
    <div class="alert alert-warning mb-3">
        @TempData["SearchError"]
    </div>
}

<div class="container mt-4">

    <!-- BANNER -->
    <div class="p-5 mb-4 text-white rounded-3 shadow"
         style="background: linear-gradient(90deg, #1a2a6c, #b21f1f, #fdbb2d);">
        <div class="text-center">
            <h1 class="fw-bold">SIÊU THỊ CÔNG NGHỆ BM</h1>
            <p>Khám phá sản phẩm với giá cực tốt</p>
        </div>
    </div>

    <div class="row">

        <!-- DANH MỤC -->
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    DANH MỤC
                </div>

                <div class="list-group list-group-flush">
                    <a asp-action="Index" class="list-group-item">Tất cả</a>

                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories)
                        {
                            <a asp-action="Index"
                               asp-route-categoryId="@cat.Id"
                               class="list-group-item">
                                @cat.Name
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- SẢN PHẨM -->
        <div class="col-md-9">

            <h4 class="mb-3">Danh sách sản phẩm (@Model.Count())</h4>

            <div class="row row-cols-1 row-cols-md-3 g-4">

                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm">

                            <!-- ẢNH -->
                            <img src="@item.ImageUrl"
                                 class="card-img-top p-3"
                                 style="height:200px;object-fit:contain"
                                 onerror="this.src='https://placehold.co/300x300'">

                            <!-- BODY -->
                            <div class="card-body text-center d-flex flex-column">

                                <span class="badge bg-primary mb-2">
                                    @item.Category?.Name
                                </span>

                                <h6 class="fw-bold">@item.Name</h6>

                                <h5 class="text-danger">
                                    @item.Price.ToString("#,##0") đ
                                </h5>

                                <div class="mt-auto">

                                    <!-- ✅ CHI TIẾT -->
                                    <a asp-controller="Product"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-outline-dark btn-sm w-100 mb-2">
                                        Chi tiết
                                    </a>

                                    <!-- ✅ GIỎ HÀNG (FIX QUAN TRỌNG) -->
                                    <form asp-controller="Carts"
                                          asp-action="AddToCart"
                                          method="post">

                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="submit"
                                                class="btn btn-warning btn-sm w-100"
                                                @(item.StockQuantity <= 0 ? "disabled" : "")>
                                            Giỏ hàng
                                        </button>
                                    </form>

                                </div>

                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</div>